{
  "name": "x-automation",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/postgame-x-bot"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm run dev --workspace @x-automation/web",
    "build": "npm run build --workspace @x-automation/web",
    "start": "npm run start --workspace @x-automation/web",
    "lint": "npm run lint --workspace @x-automation/web",
    "bot:post": "npm run post --workspace @x-automation/postgame-x-bot",
    "bot:post:x": "POST_TARGETS=x ANALYTICS_STORE_FILENAME=tweet-analytics.json npm run post --workspace @x-automation/postgame-x-bot",
    "bot:post:threads": "POST_TARGETS=threads ANALYTICS_STORE_FILENAME=threads-analytics.json npm run post --workspace @x-automation/postgame-x-bot",
    "bot:dry-run": "npm run dry-run --workspace @x-automation/postgame-x-bot",
    "bot:dry-run:x": "POST_TARGETS=x ANALYTICS_STORE_FILENAME=tweet-analytics.json npm run dry-run --workspace @x-automation/postgame-x-bot",
    "bot:dry-run:threads": "POST_TARGETS=threads ANALYTICS_STORE_FILENAME=threads-analytics.json npm run dry-run --workspace @x-automation/postgame-x-bot",
    "bot:test": "npm run test --workspace @x-automation/postgame-x-bot",
    "bot:analytics:pull": "npm run analytics:pull --workspace @x-automation/postgame-x-bot",
    "bot:analytics:pull:x": "ANALYTICS_STORE_FILENAME=tweet-analytics.json npm run analytics:pull --workspace @x-automation/postgame-x-bot",
    "bot:analytics:pull:threads": "ANALYTICS_STORE_FILENAME=threads-analytics.json npm run analytics:pull --workspace @x-automation/postgame-x-bot",
    "bot:analytics:report": "npm run analytics:report --workspace @x-automation/postgame-x-bot",
    "bot:analytics:backfill": "npm run analytics:backfill --workspace @x-automation/postgame-x-bot"
  }
}
