{
  "name": "@x-automation/postgame-x-bot",
  "version": "1.0.0",
  "description": "Automated X (Twitter) bot for postgame.ai — fetch sports data, generate posts with OpenAI, publish twice daily",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "post": "tsx src/main.ts",
    "dry-run": "POST_ENABLED=false tsx src/main.ts",
    "analytics:pull": "node --import tsx scripts/pull-analytics.ts",
    "analytics:report": "node --import tsx scripts/analytics-report.ts",
    "analytics:backfill": "node --import tsx scripts/backfill-historical-analytics.ts",
    "analytics:content-backfill": "node --import tsx scripts/backfill-content-architecture.ts",
    "threads:token:exchange": "node --import tsx scripts/threads-token.ts exchange",
    "threads:token:refresh": "node --import tsx scripts/threads-token.ts refresh",
    "test": "tsx scripts/test-validate.ts && tsx scripts/test-fetch.ts",
    "test:validate": "tsx scripts/test-validate.ts",
    "test:fetch": "tsx scripts/test-fetch.ts",
    "sample-tweets": "tsx scripts/generate-sample-tweets.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "16.6.1",
    "openai": "4.104.0",
    "twitter-api-v2": "1.29.0"
  },
  "devDependencies": {
    "@types/node": "22.19.13",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
