# X (Twitter) — OAuth 1.0 (use either naming convention)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Alternates: X_APP_KEY, X_APP_SECRET, X_ACCESS_SECRET

# LLM — OpenAI or OpenAI-compatible (e.g. Gemini)
OPENAI_API_KEY=
# Or use LLM_* (loaded from workspace .env.local):
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=
# LLM_MODEL=gemini-2.5-flash

# API-Sports (optional; fallback is ESPN)
API_SPORTS_KEY=

# Config (TARGET_SPORT: nba | nfl | mlb | soccer | auto for daily rotation)
TARGET_SPORT=auto
POST_ENABLED=true
POST_TARGETS=x
ANALYTICS_STORE_FILENAME=tweet-analytics.json

# Threads (Meta Graph API)
THREADS_ACCESS_TOKEN=
# Optional, defaults to v1.0
# THREADS_GRAPH_API_VERSION=v1.0

# Closed-loop analytics + iteration
ANALYTICS_ENABLED=true
ANALYTICS_LOOKBACK_DAYS=21
ANALYTICS_MIN_AGE_MINUTES=45
ANALYTICS_MAX_REFRESH=40
