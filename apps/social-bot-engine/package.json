{
  "name": "@x-automation/social-bot-engine",
  "version": "1.0.0",
  "description": "Multi-campaign social bot engine — fetch data, generate posts with OpenAI, publish to X and Threads",
  "type": "module",
  "main": "dist/run.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/run.js",
    "post": "tsx src/run.ts",
    "dry-run": "POST_ENABLED=false tsx src/run.ts",
    "analytics:pull": "node --import tsx scripts/pull-analytics.ts",
    "analytics:report": "node --import tsx scripts/analytics-report.ts",
    "analytics:backfill": "node --import tsx scripts/backfill-historical-analytics.ts",
    "analytics:content-backfill": "node --import tsx scripts/backfill-content-architecture.ts",
    "threads:token:exchange": "node --import tsx scripts/threads-token.ts exchange",
    "threads:token:refresh": "node --import tsx scripts/threads-token.ts refresh",
    "threads:token:refresh:campaigns": "node --import tsx scripts/refresh-campaign-threads-tokens.ts",
    "test": "tsx scripts/test-validate.ts && tsx scripts/test-fetch.ts",
    "test:campaigns": "node --import tsx scripts/test-campaign-platforms.ts",
    "test:canopy": "node --import tsx scripts/test-canopy.ts",
    "test:validate": "tsx scripts/test-validate.ts",
    "test:fetch": "tsx scripts/test-fetch.ts",
    "sample-tweets": "tsx scripts/generate-sample-tweets.ts",
    "sample-tweets:canopy": "node --import tsx scripts/generate-canopy-sample-tweets.ts",
    "preflight:prod": "node --import tsx scripts/preflight-prod.ts",
    "engage": "tsx src/runEngage.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "16.6.1",
    "openai": "4.104.0",
    "twitter-api-v2": "1.29.0"
  },
  "devDependencies": {
    "@types/node": "22.19.13",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
